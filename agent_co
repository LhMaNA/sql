# ============================================================================
# Recette Python Dataiku — Extraction COS depuis la table brute
# Input  : table transactionnelle brute (1 ligne = 1 retrait)
# Output : dataset agrege COS pret pour le notebook de visualisation
# ============================================================================

import dataiku
import pandas as pd
import numpy as np
import gc
import warnings
warnings.filterwarnings('ignore')

# ── PARAMETRES ────────────────────────────────────────────────────────────────
DATASET_BRUT    = 'retraits_transactionnel'   # <- input : table brute
DATASET_SORTIE  = 'cos_brut_agrege_2025'      # <- output : dataset agrege

ANNEE           = 2025
CHUNK_SIZE      = 500_000                     # lignes lues par chunk

# Colonnes table brute
COL_AUTOMATE    = 'automates'
COL_MONTANT     = 'montant_ope'               # en centimes
COL_DATE        = 'date_operation'
COL_RESEAU      = 'reseau'
COL_TYPE_CRO    = 'type'
COL_PRIVATIVE   = 'type_carte_privative'

# Codes CRO = vrais retraits uniquement
CODES_CRO_OK    = ['AXA', '60']

# Identification COS — double condition pour fiabilite
CODE_RESEAU_COS = '11'
CODE_PRIVAT_COS = 'COS'

# ── 1. LECTURE PAR CHUNKS ─────────────────────────────────────────────────────
print("Lecture de la table brute par chunks de {:,} lignes...".format(CHUNK_SIZE))

COLONNES = [
    COL_AUTOMATE, COL_MONTANT, COL_DATE,
    COL_RESEAU, COL_TYPE_CRO, COL_PRIVATIVE,
]

ds_brut = dataiku.Dataset(DATASET_BRUT)
reader  = ds_brut.get_dataframe_iterator(
    chunksize=CHUNK_SIZE,
    columns=COLONNES,
)

chunks_cos = []
total_lus  = 0
total_cos  = 0

for i, chunk in enumerate(reader):
    total_lus += len(chunk)

    # Typage date
    chunk[COL_DATE] = pd.to_datetime(chunk[COL_DATE], errors='coerce')

    # Filtres en cascade
    mask_annee = (chunk[COL_DATE].dt.year == ANNEE)
    mask_cro   = chunk[COL_TYPE_CRO].isin(CODES_CRO_OK)
    mask_cos   = (
        (chunk[COL_RESEAU].astype(str).str.strip() == CODE_RESEAU_COS) |
        (chunk[COL_PRIVATIVE].astype(str).str.strip().str.upper() == CODE_PRIVAT_COS)
    )

    cos_chunk = chunk[mask_annee & mask_cro & mask_cos].copy()
    total_cos += len(cos_chunk)

    if len(cos_chunk) > 0:
        chunks_cos.append(cos_chunk)

    del chunk, cos_chunk
    gc.collect()

    if (i + 1) % 5 == 0:
        print("  Chunk {:3d} | {:,} lignes lues | {:,} COS retenus".format(
            i + 1, total_lus, total_cos))

print("\nLecture terminee :")
print("  Total lignes lues  : {:,}".format(total_lus))
print("  Lignes COS retenues: {:,}".format(total_cos))

if len(chunks_cos) == 0:
    raise ValueError(
        "Aucune ligne COS trouvee. "
        "Verifiez CODES_CRO_OK, CODE_RESEAU_COS et CODE_PRIVAT_COS."
    )

# ── 2. CONSOLIDATION ─────────────────────────────────────────────────────────
print("\nConsolidation des chunks...")

df = pd.concat(chunks_cos, ignore_index=True)
del chunks_cos
gc.collect()

# Renommage + enrichissement
df = df.rename(columns={COL_AUTOMATE: 'num_automate'})
df['montant_eur'] = df[COL_MONTANT] / 100.0
df['mois']        = df[COL_DATE].dt.month
df['heure']       = df[COL_DATE].dt.hour
df['jour_semaine']= df[COL_DATE].dt.dayofweek  # 0=lundi ... 6=dimanche
df['est_weekend'] = df['jour_semaine'].isin([5, 6]).astype(int)
df['est_nuit']    = df['heure'].isin(range(0, 6)).astype(int)

NOMS_MOIS = {
    1:'Jan', 2:'Fev', 3:'Mar', 4:'Avr', 5:'Mai',  6:'Jun',
    7:'Jul', 8:'Aou', 9:'Sep', 10:'Oct', 11:'Nov', 12:'Dec'
}
df['mois_nom'] = df['mois'].map(NOMS_MOIS)

print("Consolidation OK : {:,} lignes | {:,} GAB".format(
    len(df), df['num_automate'].nunique()))

# ── 3. AGREGATION PAR GAB ─────────────────────────────────────────────────────
print("\nAgregation par GAB...")

agg_gab = df.groupby('num_automate').agg(
    nb_operations      = ('montant_eur',  'count'),
    montant_total_eur  = ('montant_eur',  'sum'),
    montant_moyen_eur  = ('montant_eur',  'mean'),
    montant_max_eur    = ('montant_eur',  'max'),
    nb_jours_actifs    = (COL_DATE,       'nunique'),
    nb_mois_actifs     = ('mois',         'nunique'),
    nb_retraits_nuit   = ('est_nuit',     'sum'),
    nb_retraits_weekend= ('est_weekend',  'sum'),
    premiere_op        = (COL_DATE,       'min'),
    derniere_op        = (COL_DATE,       'max'),
).reset_index()

# Calcul des pourcentages
agg_gab['pct_nuit']    = (
    agg_gab['nb_retraits_nuit']    / agg_gab['nb_operations'] * 100
).round(2)
agg_gab['pct_weekend'] = (
    agg_gab['nb_retraits_weekend'] / agg_gab['nb_operations'] * 100
).round(2)
agg_gab['montant_moyen_eur'] = agg_gab['montant_moyen_eur'].round(2)
agg_gab['montant_total_eur'] = agg_gab['montant_total_eur'].round(2)

# Formatage dates
agg_gab['premiere_op'] = agg_gab['premiere_op'].dt.strftime('%Y-%m-%d')
agg_gab['derniere_op'] = agg_gab['derniere_op'].dt.strftime('%Y-%m-%d')
agg_gab['annee']       = ANNEE

agg_gab = agg_gab.sort_values('nb_operations', ascending=False).reset_index(drop=True)

# ── 4. AGREGATION PAR GAB x MOIS ─────────────────────────────────────────────
print("Agregation par GAB x mois...")

agg_gab_mois = df.groupby(['num_automate', 'mois', 'mois_nom']).agg(
    nb_operations     = ('montant_eur', 'count'),
    montant_total_eur = ('montant_eur', 'sum'),
    montant_moyen_eur = ('montant_eur', 'mean'),
    nb_nuit           = ('est_nuit',    'sum'),
    nb_weekend        = ('est_weekend', 'sum'),
).reset_index()

agg_gab_mois['montant_total_eur'] = agg_gab_mois['montant_total_eur'].round(2)
agg_gab_mois['montant_moyen_eur'] = agg_gab_mois['montant_moyen_eur'].round(2)
agg_gab_mois['annee']             = ANNEE
agg_gab_mois = agg_gab_mois.sort_values(['num_automate', 'mois'])

# ── 5. AGREGATION PAR MOIS ───────────────────────────────────────────────────
print("Agregation par mois...")

agg_mois = df.groupby(['mois', 'mois_nom']).agg(
    nb_operations     = ('montant_eur', 'count'),
    montant_total_eur = ('montant_eur', 'sum'),
    montant_moyen_eur = ('montant_eur', 'mean'),
    nb_gab_actifs     = ('num_automate','nunique'),
    nb_nuit           = ('est_nuit',    'sum'),
    nb_weekend        = ('est_weekend', 'sum'),
).reset_index().sort_values('mois')

agg_mois['pct_nuit']    = (agg_mois['nb_nuit']    / agg_mois['nb_operations'] * 100).round(2)
agg_mois['pct_weekend'] = (agg_mois['nb_weekend']  / agg_mois['nb_operations'] * 100).round(2)
agg_mois['montant_total_eur'] = agg_mois['montant_total_eur'].round(2)
agg_mois['montant_moyen_eur'] = agg_mois['montant_moyen_eur'].round(2)
agg_mois['annee'] = ANNEE

# ── 6. AGREGATION PAR HEURE ──────────────────────────────────────────────────
print("Agregation par heure...")

agg_heure = df.groupby('heure').agg(
    nb_operations     = ('montant_eur', 'count'),
    montant_total_eur = ('montant_eur', 'sum'),
    montant_moyen_eur = ('montant_eur', 'mean'),
    nb_gab_actifs     = ('num_automate','nunique'),
).reset_index().sort_values('heure')

agg_heure['montant_total_eur'] = agg_heure['montant_total_eur'].round(2)
agg_heure['montant_moyen_eur'] = agg_heure['montant_moyen_eur'].round(2)
agg_heure['annee'] = ANNEE

# ── 7. LOGS DE CONTROLE ───────────────────────────────────────────────────────
print("\n" + "=" * 55)
print("RESUME COS {} — TABLE BRUTE".format(ANNEE))
print("=" * 55)
print("  Nb operations COS    : {:,}".format(int(agg_gab['nb_operations'].sum())))
print("  Nb GAB concernes     : {:,}".format(len(agg_gab)))
print("  Montant total (EUR)  : {:,.2f}".format(agg_gab['montant_total_eur'].sum()))
print("  Montant moyen (EUR)  : {:.2f}".format(agg_gab['montant_moyen_eur'].mean()))
print("  % retraits nuit moy. : {:.2f}%".format(agg_gab['pct_nuit'].mean()))
print("  % retraits wkd moy.  : {:.2f}%".format(agg_gab['pct_weekend'].mean()))
print()
print("Top 5 GAB par volume COS :")
cols_affich = ['num_automate','nb_operations','montant_total_eur',
               'pct_nuit','pct_weekend','nb_mois_actifs']
print(agg_gab[cols_affich].head(5).to_string(index=False))

# ── 8. ECRITURE DATASET DATAIKU ───────────────────────────────────────────────
# On concatene les 4 agregations dans un seul dataset de sortie
# Le notebook en aval pourra filtrer sur la colonne 'granularite'
print("\nEcriture du dataset de sortie '{}'...".format(DATASET_SORTIE))

agg_gab['granularite']      = 'par_gab'
agg_gab_mois['granularite'] = 'par_gab_mois'
agg_mois['granularite']     = 'par_mois'
agg_heure['granularite']    = 'par_heure'

df_sortie = pd.concat([
    agg_gab, agg_gab_mois, agg_mois, agg_heure
], ignore_index=True, sort=False)

ds_sortie = dataiku.Dataset(DATASET_SORTIE)
ds_sortie.write_with_schema(df_sortie)

print("Dataset ecrit : {:,} lignes x {} colonnes".format(
    len(df_sortie), len(df_sortie.columns)))
print("\nColonnes disponibles pour le notebook :")
for col in sorted(df_sortie.columns):
    print("  - {}".format(col))

print("\nScript termine avec succes.")
